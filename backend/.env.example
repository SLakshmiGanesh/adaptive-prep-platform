# Adaptive Prep Platform v2 — Backend Environment Variables
# Copy to .env and fill in real values

# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://learning:learning@localhost:5432/adaptiveprep
REDIS_URL=redis://localhost:6379

# ── Auth ──────────────────────────────────────────────────────────────────────
JWT_SECRET=replace-with-random-64-char-string-in-production
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=10080

# ── OpenAI — REQUIRED for AI Tutor ───────────────────────────────────────────
# Get your key at: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-proj-...
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
OPENAI_CHAT_MODEL=gpt-4o-mini

# ── App ───────────────────────────────────────────────────────────────────────
ENVIRONMENT=development
